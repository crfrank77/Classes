clear;
close all;

omega = pi;
t = 0:0.001:5;

yt = sin(omega*t);

h = 0.1;
t_k = 0:h:5; 
y_k = sin(omega*t_k);

y_zoh = t.*0;

for i = 1:51   
    for j = 0:0.001:0.1
    y_zoh(i) = y_k(1)+y_k(i+1)*dirac(j);
    end
end

figure(1);
hold on
plot(t,yt,'--b');
plot(t_k,y_k,'xk');
plot(t_k,y_zoh,'-k');